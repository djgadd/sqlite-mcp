{
  "name": "node-sqlite-mcp",
  "version": "0.1.0",
  "description": "MCP server for querying SQLite database files. Uses Node's built-in node:sqlite, so it has no native/system dependencies.",
  "type": "module",
  "bin": {
    "node-sqlite-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "test": "npm run build && node --test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sqlite",
    "database"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/djgadd/sqlite-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/djgadd/sqlite-mcp/issues"
  },
  "homepage": "https://github.com/djgadd/sqlite-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.6.0"
  }
}
